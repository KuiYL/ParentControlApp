<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ParentControlApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/green_400</item>
        <item name="colorPrimaryVariant">@color/green_600</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorSecondaryVariant">@color/green_500</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:colorBackground">@color/gray_900</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOutline">#424242</item>

        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/gray_300</item>
        <item name="android:textColorHint">@color/gray_600</item>

        <item name="textAppearanceBody1">@style/TextAppearance.MaterialComponents.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="textAppearanceButton">@style/TextAppearance.MaterialComponents.Button</item>

        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox
        </item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>

        <item name="android:statusBarColor">@color/green_900</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>


    <style name="ThemeOverlay.AppTheme.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorOnSurface">@color/gray_300</item>
        <item name="android:textColorPrimary">@color/gray_300</item>
        <item name="android:textColorSecondary">@color/gray_300</item>
        <item name="colorPrimary">@color/green_400</item>
        <item name="colorSurface">#1E1E1E</item>
    </style>

    <style name="Widget.AppTheme.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/green_600</item>
        <item name="boxStrokeErrorColor">@color/status_blocked</item>
        <item name="android:textColor">@color/gray_900</item>
        <item name="hintTextColor">@color/gray_600</item>
        <item name="startIconTint">@color/green_600</item>
        <item name="endIconTint">@color/green_600</item>
        <item name="boxBackgroundColor">@color/background_secondary</item>
    </style>
</resources>

