<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <FrameLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_circle_green_light">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="@color/green_700" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Пока нет данных"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_empty_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Активность появится, когда ребёнок воспользуется устройством"
        android:textColor="@color/text_hint"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_retry"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="Обновить"
        android:textColor="@color/green_600"
        android:textSize="14sp"
        app:cornerRadius="22dp"
        app:icon="@android:drawable/ic_popup_sync"
        app:iconPadding="8dp"
        app:iconSize="18dp"
        app:iconTint="@color/green_600"
        app:strokeColor="@color/green_600" />
</LinearLayout>